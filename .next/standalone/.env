# Banco de dados SQLite
DATABASE_URL="file:./dev.db"

# Chave secreta para autenticação
# Gere com: openssl rand -base64 32

AUTH_SECRET="sua-chave-secreta-aqui-minimo-32-caracteres"

# URL publica do seu dominio
NEXTAUTH_URL="https://seudominio.com.br"

# Token de segurança para promoção de admin via API
# Altere para um valor único e seguro em produção
SETUP_TOKEN="psycho-manager-2024"

# Dados do admin padrão (criado automaticamente no primeiro deploy)
# Deixe em branco para usar os valores padrão
ADMIN_EMAIL="admin@psychomanager.com"
ADMIN_PASSWORD="Admin@1234"
ADMIN_NAME="Administrador"

# Ambiente
NODE_ENV="production"
