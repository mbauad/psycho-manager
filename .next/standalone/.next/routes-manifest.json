{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/auth/[...nextauth]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPnextauth": "nxtPnextauth"
      },
      "namedRegex": "^/api/auth/(?<nxtPnextauth>.+?)(?:/)?$"
    },
    {
      "page": "/pacientes/[id]",
      "regex": "^/pacientes/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/pacientes/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/pacientes/[id]/editar",
      "regex": "^/pacientes/([^/]+?)/editar(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/pacientes/(?<nxtPid>[^/]+?)/editar(?:/)?$"
    },
    {
      "page": "/pacientes/[id]/prontuario",
      "regex": "^/pacientes/([^/]+?)/prontuario(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/pacientes/(?<nxtPid>[^/]+?)/prontuario(?:/)?$"
    },
    {
      "page": "/sessoes/[id]",
      "regex": "^/sessoes/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/sessoes/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/sessoes/[id]/editar",
      "regex": "^/sessoes/([^/]+?)/editar(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/sessoes/(?<nxtPid>[^/]+?)/editar(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/admin",
      "regex": "^/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin(?:/)?$"
    },
    {
      "page": "/agenda",
      "regex": "^/agenda(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/agenda(?:/)?$"
    },
    {
      "page": "/configuracoes",
      "regex": "^/configuracoes(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/configuracoes(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/financeiro",
      "regex": "^/financeiro(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/financeiro(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/pacientes",
      "regex": "^/pacientes(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/pacientes(?:/)?$"
    },
    {
      "page": "/pacientes/novo",
      "regex": "^/pacientes/novo(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/pacientes/novo(?:/)?$"
    },
    {
      "page": "/register",
      "regex": "^/register(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/register(?:/)?$"
    },
    {
      "page": "/relatorios",
      "regex": "^/relatorios(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/relatorios(?:/)?$"
    },
    {
      "page": "/sessoes",
      "regex": "^/sessoes(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sessoes(?:/)?$"
    },
    {
      "page": "/sessoes/nova",
      "regex": "^/sessoes/nova(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sessoes/nova(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}